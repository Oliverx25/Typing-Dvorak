---
import Layout from '../layouts/Layout.astro';
import LandingPage from '../components/pages/landing/LandingPage';

export const prerender = true;
---

<Layout
  title="Typing Dvorak — Learn Touch Typing Faster"
  description="Master the Dvorak keyboard with progressive lessons, live feedback, and optional cloud sync."
>
  <LandingPage client:only="react">
    <div slot="fallback" class="flex min-h-screen flex-col items-center justify-center gap-4 px-4">
      <div class="h-10 w-10 animate-spin rounded-full border-2 border-[var(--color-border)] border-t-[var(--color-highlight)]"></div>
      <p class="text-sm text-[var(--color-text-muted)]">Loading…</p>
    </div>
  </LandingPage>
</Layout>
