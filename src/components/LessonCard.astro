---
interface Props {
  id: string;
  title: string;
  description: string;
  category: string;
  difficulty: number;
}

const { id, title, description, category, difficulty } = Astro.props;

const difficultyLabels = ['', 'Beginner', 'Easy', 'Medium', 'Hard', 'Expert'];
const categoryLabels: Record<string, string> = {
  drill: 'Key Drill',
  words: 'Words',
  sentences: 'Sentences',
};
---

<a
  href={`/lesson/${id}`}
  class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5 no-underline transition hover:border-[var(--color-accent)] hover:shadow-md"
>
  <div class="mb-3 flex items-center justify-between">
    <span class="rounded-full bg-[var(--color-accent)]/10 px-2.5 py-0.5 text-xs font-medium text-[var(--color-accent)]">
      {categoryLabels[category] ?? category}
    </span>
    <span class="text-xs text-[var(--color-text-muted)]">{difficultyLabels[difficulty]}</span>
  </div>
  <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
    {title}
  </h3>
  <p class="mt-1.5 text-sm text-[var(--color-text-muted)]">{description}</p>
  <p class="mt-4 text-sm font-medium text-[var(--color-accent)]">
    Start lesson →
  </p>
</a>
