---
import AppLayout from '../../layouts/AppLayout.astro';
import MultiplayerAppRoot from '../../components/pages/multiplayer/MultiplayerAppRoot';

export const prerender = true;

const kicked = Astro.url.searchParams.get('kicked') === '1';
const roomClosed = Astro.url.searchParams.get('room_closed') === '1';
---

<AppLayout title="Typing Dvorak — Multiplayer">
  <MultiplayerAppRoot client:load kicked={kicked} roomClosed={roomClosed} />
</AppLayout>
