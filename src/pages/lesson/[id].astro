---
import AppLayout from '@/layouts/AppLayout.astro';
import LessonAppRoot from '@/components/pages/lessons/LessonAppRoot';
import { getLessons } from '@/utils/curriculum/lessons';

export const prerender = true;

export function getStaticPaths() {
  return getLessons().map((lesson) => ({ params: { id: lesson.id } }));
}

const { id } = Astro.params;
---

<AppLayout title="Typing Dvorak — Lesson">
  <LessonAppRoot client:load lessonId={id!} />
</AppLayout>
